{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/check-secrets.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/block-dangerous.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/lint-file.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/typecheck-file.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/test-related.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/check-hex-colours.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/check-openapi-drift.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/dev/hooks/context-loader.sh"
          }
        ]
      }
    ]
  }
}
