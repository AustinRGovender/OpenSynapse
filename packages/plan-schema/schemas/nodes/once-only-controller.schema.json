{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensynapse.dev/schemas/nodes/once-only-controller.schema.json",
  "title": "Once-Only Controller",
  "description": "Children run once per VU regardless of how many iterations the VU performs. Used for setup steps like logging in.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this node."
    },
    "type": {
      "const": "once-only-controller",
      "description": "Node type discriminator."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Human-readable name of this controller."
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether this node is enabled."
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Child nodes that run once per VU on the first iteration only."
    }
  },
  "required": ["id", "type", "name", "enabled", "children"],
  "additionalProperties": false
}
