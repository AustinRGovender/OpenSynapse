{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri-conf-schema/refs/heads/master/schema/tauri-conf-schema.json",
  "productName": "OpenSynapse",
  "version": "0.0.0",
  "identifier": "com.opensynapse.app",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build"
  },
  "app": {
    "title": "OpenSynapse",
    "windows": [
      {
        "title": "OpenSynapse",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
