{
  "name": "Full Node Type Fixture",
  "description": "A test plan that exercises every node type",
  "tags": ["fixture", "smoke"],
  "root": {
    "id": "root-1",
    "type": "plan",
    "name": "Full Test Plan",
    "enabled": true,
    "properties": {
      "description": "Exercises all node types",
      "tags": ["fixture"]
    },
    "children": [
      {
        "id": "env-bind-1",
        "type": "environment-binding",
        "name": "Staging Environment",
        "enabled": true,
        "properties": {
          "environment_id": "00000000-0000-0000-0000-000000000001"
        },
        "children": []
      },
      {
        "id": "ds-1",
        "type": "data-source",
        "name": "Users CSV",
        "enabled": true,
        "properties": {
          "source_type": "csv",
          "path": "data/users.csv",
          "delimiter": ",",
          "sharing": "shared",
          "variable_name": "users",
          "first_row_is_header": true
        },
        "children": []
      },
      {
        "id": "scenario-1",
        "type": "scenario",
        "name": "Main Load Scenario",
        "enabled": true,
        "properties": {
          "executor": "externally-controlled",
          "vus": 10,
          "max_vus": 100,
          "duration": "10m"
        },
        "children": [
          {
            "id": "once-1",
            "type": "once-only-controller",
            "name": "Login Setup",
            "enabled": true,
            "properties": {},
            "children": [
              {
                "id": "http-login",
                "type": "http",
                "name": "POST Login",
                "enabled": true,
                "properties": {
                  "method": "POST",
                  "url": "${BASE_URL}/api/login",
                  "headers": [
                    { "key": "Content-Type", "value": "application/json" }
                  ],
                  "body": {
                    "type": "json",
                    "content": "{\"username\":\"${users.username}\",\"password\":\"${users.password}\"}"
                  },
                  "timeout": "30s",
                  "follow_redirects": true
                },
                "children": [
                  {
                    "id": "assert-login-status",
                    "type": "assertion",
                    "name": "Check 200",
                    "enabled": true,
                    "properties": {
                      "target": "status",
                      "condition": "equals",
                      "value": 200,
                      "negate": false
                    },
                    "children": []
                  },
                  {
                    "id": "timer-login",
                    "type": "timer",
                    "name": "Think Time",
                    "enabled": true,
                    "properties": {
                      "timer_type": "constant",
                      "duration_ms": 1000
                    },
                    "children": []
                  }
                ]
              }
            ]
          },
          {
            "id": "tx-browse",
            "type": "transaction-controller",
            "name": "Browse Products",
            "enabled": true,
            "properties": {},
            "children": [
              {
                "id": "http-list",
                "type": "http",
                "name": "GET Products",
                "enabled": true,
                "properties": {
                  "method": "GET",
                  "url": "${BASE_URL}/api/products",
                  "headers": [],
                  "body": { "type": "none" },
                  "follow_redirects": true
                },
                "children": [
                  {
                    "id": "assert-list-body",
                    "type": "assertion",
                    "name": "Has products",
                    "enabled": true,
                    "properties": {
                      "target": "body",
                      "condition": "jsonpath",
                      "value": "$.items",
                      "negate": false
                    },
                    "children": []
                  }
                ]
              },
              {
                "id": "if-has-products",
                "type": "if-controller",
                "name": "If products exist",
                "enabled": true,
                "properties": {
                  "condition": "response.json().items.length > 0"
                },
                "children": [
                  {
                    "id": "http-detail",
                    "type": "http",
                    "name": "GET Product Detail",
                    "enabled": true,
                    "properties": {
                      "method": "GET",
                      "url": "${BASE_URL}/api/products/1",
                      "headers": [],
                      "body": { "type": "none" }
                    },
                    "children": []
                  }
                ]
              },
              {
                "id": "else-no-products",
                "type": "else-controller",
                "name": "Else no products",
                "enabled": true,
                "properties": {},
                "children": [
                  {
                    "id": "code-log",
                    "type": "code-block",
                    "name": "Log empty",
                    "enabled": true,
                    "properties": {
                      "code": "console.log('No products found');"
                    },
                    "children": []
                  }
                ]
              }
            ]
          },
          {
            "id": "loop-1",
            "type": "loop-controller",
            "name": "Add 3 items to cart",
            "enabled": true,
            "properties": {
              "count": 3
            },
            "children": [
              {
                "id": "http-add-cart",
                "type": "http",
                "name": "POST Add to Cart",
                "enabled": true,
                "properties": {
                  "method": "POST",
                  "url": "${BASE_URL}/api/cart",
                  "headers": [
                    { "key": "Content-Type", "value": "application/json" }
                  ],
                  "body": {
                    "type": "json",
                    "content": "{\"product_id\": 1, \"quantity\": 1}"
                  }
                },
                "children": [
                  {
                    "id": "timer-cart",
                    "type": "timer",
                    "name": "Random Pause",
                    "enabled": true,
                    "properties": {
                      "timer_type": "uniform_random",
                      "min_ms": 500,
                      "max_ms": 2000
                    },
                    "children": []
                  }
                ]
              }
            ]
          },
          {
            "id": "random-1",
            "type": "random-controller",
            "name": "Random Action",
            "enabled": true,
            "properties": {
              "weights": [70, 30]
            },
            "children": [
              {
                "id": "http-search",
                "type": "http",
                "name": "GET Search",
                "enabled": true,
                "properties": {
                  "method": "GET",
                  "url": "${BASE_URL}/api/search?q=widget",
                  "headers": [],
                  "body": { "type": "none" }
                },
                "children": []
              },
              {
                "id": "ws-notifications",
                "type": "websocket",
                "name": "WS Notifications",
                "enabled": true,
                "properties": {
                  "url": "${WS_URL}/ws/notifications",
                  "connect_timeout": "5s",
                  "messages": [
                    { "type": "text", "data": "{\"subscribe\":\"updates\"}", "delay_before": "0s" }
                  ],
                  "expected_messages": [
                    { "match_type": "contains", "value": "subscribed", "timeout": "10s" }
                  ],
                  "disconnect_behavior": "close_gracefully"
                },
                "children": []
              }
            ]
          }
        ]
      }
    ]
  }
}
