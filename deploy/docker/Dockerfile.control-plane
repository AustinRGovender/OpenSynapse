FROM golang:1.25-alpine AS builder

WORKDIR /build
COPY apps/control-plane/go.mod apps/control-plane/go.sum* ./
RUN go mod download 2>/dev/null || true
COPY apps/control-plane/ .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /opensynapse-control ./cmd/server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates chromium nss freetype harfbuzz
ENV ROD_BROWSER_BIN=/usr/bin/chromium-browser
COPY --from=builder /opensynapse-control /usr/local/bin/opensynapse-control
EXPOSE 8090
ENTRYPOINT ["opensynapse-control"]
